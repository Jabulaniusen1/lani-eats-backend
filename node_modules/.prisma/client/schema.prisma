generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  RIDER
  MERCHANT
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  UNASSIGNED
  ASSIGNED
  PICKED_UP
  DELIVERED
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  phone      String   @unique
  password   String
  firstName  String
  lastName   String
  role       Role     @default(CUSTOMER)
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  reviews   Review[]
  merchant  Merchant?
  rider     Rider?
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  label     String // e.g "Home", "Work"
  street    String
  city      String
  state     String
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]
}

model Merchant {
  id            String   @id @default(uuid())
  userId        String   @unique
  businessName  String
  businessPhone String
  isApproved    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user           User                 @relation(fields: [userId], references: [id])
  restaurants    Restaurant[]
  bankAccount    MerchantBankAccount?
  payoutRequests PayoutRequest[]
}

model Restaurant {
  id           String   @id @default(uuid())
  merchantId   String
  name         String
  description  String?
  address      String
  city         String
  state        String
  latitude     Float?
  longitude    Float?
  logoUrl      String?
  coverUrl     String?
  isOpen       Boolean  @default(false)
  isApproved   Boolean  @default(false)
  openingTime  String? // "08:00"
  closingTime  String? // "22:00"
  rating       Float    @default(0)
  totalReviews Int      @default(0)
  isBusy       Boolean  @default(false)
  busyMessage  String?
  avgPrepTime  Int      @default(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  merchant   Merchant             @relation(fields: [merchantId], references: [id])
  menuItems  MenuItem[]
  orders     Order[]
  reviews    Review[]
  categories RestaurantCategory[]
}

model RestaurantCategory {
  id           String @id @default(uuid())
  restaurantId String
  name         String // e.g "Burgers", "Drinks", "Sides"

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems  MenuItem[]
}

model MenuItem {
  id           String   @id @default(uuid())
  restaurantId String
  categoryId   String?
  name         String
  description  String?
  price        Float
  imageUrl     String?
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant          @relation(fields: [restaurantId], references: [id])
  category   RestaurantCategory? @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
}

model Order {
  id                String        @id @default(uuid())
  userId            String
  restaurantId      String
  addressId         String
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  paymentRef        String?
  subtotal          Float
  deliveryFee       Float
  serviceCharge     Float         @default(200)
  total             Float
  note              String?
  estimatedPrepTime Int?
  cancelReason      String?
  cancelledBy       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  address    Address     @relation(fields: [addressId], references: [id])
  items      OrderItem[]
  delivery   Delivery?
  review     Review?
}

model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Float
  totalPrice Float

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

model Rider {
  id               String   @id @default(uuid())
  userId           String   @unique
  vehicleType      String // "bike", "bicycle", "car"
  vehiclePlate     String?
  isAvailable      Boolean  @default(false)
  isApproved       Boolean  @default(false)
  currentLatitude  Float?
  currentLongitude Float?
  rating           Float    @default(0)
  totalReviews     Int      @default(0)
  totalDeclined    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User                 @relation(fields: [userId], references: [id])
  deliveries     Delivery[]
  reviews        Review[]
  bankAccount    RiderBankAccount?
  payoutRequests RiderPayoutRequest[]
  issues         DeliveryIssue[]
}

model Delivery {
  id            String         @id @default(uuid())
  orderId       String         @unique
  riderId       String?
  status        DeliveryStatus @default(UNASSIGNED)
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  photoProofUrl String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  order  Order           @relation(fields: [orderId], references: [id])
  rider  Rider?          @relation(fields: [riderId], references: [id])
  issues DeliveryIssue[]
}

model Review {
  id           String   @id @default(uuid())
  userId       String
  orderId      String   @unique
  restaurantId String?
  riderId      String?
  rating       Int // 1-5
  comment      String?
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  order      Order       @relation(fields: [orderId], references: [id])
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])
  rider      Rider?      @relation(fields: [riderId], references: [id])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DeliveryIssueType {
  CANT_FIND_CUSTOMER
  WRONG_ADDRESS
  CUSTOMER_REFUSED
  ITEM_DAMAGED
  RESTAURANT_NOT_READY
  OTHER
}

model MerchantBankAccount {
  id            String   @id @default(uuid())
  merchantId    String   @unique
  accountName   String
  accountNumber String
  bankName      String
  bankCode      String
  recipientCode String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])
}

model PayoutRequest {
  id            String       @id @default(uuid())
  merchantId    String
  amount        Float
  status        PayoutStatus @default(PENDING)
  reference     String?
  narration     String?
  failureReason String?
  requestedAt   DateTime     @default(now())
  processedAt   DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])
}

model RiderBankAccount {
  id            String   @id @default(uuid())
  riderId       String   @unique
  accountName   String
  accountNumber String
  bankName      String
  bankCode      String
  recipientCode String?
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rider Rider @relation(fields: [riderId], references: [id])
}

model RiderPayoutRequest {
  id            String       @id @default(uuid())
  riderId       String
  amount        Float
  status        PayoutStatus @default(PENDING)
  reference     String?
  narration     String?
  failureReason String?
  requestedAt   DateTime     @default(now())
  processedAt   DateTime?

  rider Rider @relation(fields: [riderId], references: [id])
}

model DeliveryIssue {
  id          String            @id @default(uuid())
  deliveryId  String
  riderId     String
  type        DeliveryIssueType
  description String?
  resolvedAt  DateTime?
  createdAt   DateTime          @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id])
  rider    Rider    @relation(fields: [riderId], references: [id])
}
